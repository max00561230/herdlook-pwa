<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>HerdLook v1.2 — Herd Management</title>
<meta name="theme-color" content="#183326">
<meta name="description" content="HerdLook v1.2 — Camera-assisted herd records for livestock owners. Manage animals, photos, records, and camera lookup.">
<style>
:root{--bg:#f5f1e7;--card:#fffdf8;--ink:#17241d;--muted:#68746c;--green:#183326;--green2:#2f604b;--gold:#c58b35;--line:#ddd5c7;--bad:#a33b2f;--shadow:0 14px 38px rgba(23,36,29,.12);--r:18px}
*{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;background:radial-gradient(circle at top left,#fff8ea,var(--bg));color:var(--ink)}button,input,select,textarea{font:inherit}button{cursor:pointer;border:0}.hidden{display:none!important}
.appbar{display:none;position:sticky;top:0;z-index:40;align-items:center;justify-content:space-between;padding:12px 14px;background:rgba(245,241,231,.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}.mbrand{display:flex;align-items:center;gap:10px;min-width:0}.logo{width:46px;height:46px;border-radius:14px;display:grid;place-items:center;background:#eaf2ec;color:var(--green);font-size:25px;border:1px solid #d6e4d9}.mbrand strong{font-size:20px;display:block}.mbrand small{display:block;color:var(--muted);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:230px}.hamb{width:48px;height:48px;border-radius:15px;background:var(--green);color:white;font-size:24px}.backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.36);z-index:44}.backdrop.open{display:block}
.layout{display:grid;grid-template-columns:290px minmax(0,1fr);min-height:100vh}.side{position:sticky;top:0;height:100vh;padding:22px;background:linear-gradient(180deg,#142a20,#1f4033);color:white;overflow:auto;z-index:45}.brand{display:flex;gap:12px;align-items:center;margin-bottom:18px}.brand h1{margin:0;font-size:30px}.brand p{margin:2px 0;color:rgba(255,255,255,.7)}.byline{font-size:13px;letter-spacing:.08em;color:rgba(255,255,255,.62)}
.nav{display:grid;gap:8px;margin-top:18px}.nav button{display:flex;gap:10px;align-items:center;text-align:left;width:100%;border-radius:14px;padding:12px;color:rgba(255,255,255,.88);background:transparent}.nav button.active,.nav button:hover{background:rgba(255,255,255,.14);color:white}.nav .label{overflow:hidden;text-overflow:ellipsis}
main{padding:24px;min-width:0}.top{display:flex;justify-content:space-between;gap:14px;align-items:start;margin-bottom:18px}.top h2{font-size:clamp(28px,4vw,44px);line-height:1;margin:0;letter-spacing:-.05em}.top p{color:var(--muted);margin:7px 0 0}.actions{display:flex;gap:9px;flex-wrap:wrap}.btn{border-radius:14px;padding:11px 14px;min-height:44px;background:var(--card);border:1px solid var(--line);color:var(--ink);box-shadow:0 5px 14px rgba(23,36,29,.06)}.primary{background:var(--green);color:white;border-color:transparent}.accent{background:var(--gold);color:white;border-color:transparent}.danger{background:#fff0ed;color:var(--bad);border-color:#efc9c3}
.card{background:rgba(255,253,248,.9);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);padding:17px}.grid{display:grid;gap:14px}.stats{grid-template-columns:repeat(4,1fr)}.three{grid-template-columns:repeat(3,1fr)}.two{grid-template-columns:repeat(2,1fr)}.stat small,.muted{color:var(--muted)}.stat strong{font-size:38px;display:block;margin:10px 0}.notice{border:1px solid #ead8ba;background:#fff8ea;color:#6b4a19;border-radius:15px;padding:12px;margin-bottom:14px;line-height:1.45}
.toolbar{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:14px}.toolbar input,.toolbar select{flex:1;min-width:150px}.field{display:grid;gap:6px;margin-bottom:11px}label{font-weight:800;font-size:13px;color:#344238}input,select,textarea{width:100%;border:1px solid var(--line);border-radius:13px;background:#fffdf8;color:var(--ink);padding:11px;min-height:44px}textarea{min-height:92px;resize:vertical}.formgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:11px}.full{grid-column:1/-1}
.catcard{text-align:left;display:grid;gap:8px;min-height:118px}.catcard small{color:var(--muted)}.catcard strong{font-size:32px}.catcard.active{border-color:var(--green2);box-shadow:0 0 0 3px rgba(47,96,75,.14),var(--shadow)}.idgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:12px}.idbtn{text-align:left;border:1px solid var(--line);background:#fffdf8;border-radius:14px;padding:12px}.idbtn strong{display:block;font-size:18px}.animals{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.pill{display:inline-flex;border-radius:99px;padding:5px 9px;background:#eef5ef;color:var(--green);font-size:12px;font-weight:900;border:1px solid #d6e4d9}.record,.doc,.loc{border:1px solid var(--line);border-radius:15px;background:#fffdf8;padding:12px;margin-top:10px}.row{display:flex;justify-content:space-between;align-items:center;gap:10px}
.photos{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.photoCard{border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fffdf8}.photoCard img,.thumb img{width:100%;height:210px;object-fit:cover;display:block}.thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.thumb{height:130px;border:1px solid var(--line);border-radius:14px;overflow:hidden;background:#f6f1e7}.match{display:grid;grid-template-columns:105px 1fr auto;gap:12px;align-items:center;border:1px solid var(--line);border-radius:16px;padding:10px;background:#fffdf8;margin-top:10px}.match img{width:105px;height:86px;object-fit:cover;border-radius:12px}.bar{height:9px;background:#e7dfd1;border-radius:99px;overflow:hidden}.bar span{display:block;height:100%;background:linear-gradient(90deg,var(--green2),var(--gold))}
.batch{display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:10px;align-items:end;border:1px solid var(--line);border-radius:15px;background:#fffdf8;padding:12px;margin-top:10px}.chips{display:flex;gap:7px;flex-wrap:wrap}.chip{border:1px solid var(--line);background:#fffdf8;border-radius:99px;padding:6px 10px;font-size:12px;font-weight:800;color:var(--green)}
.modal{display:none;position:fixed;inset:0;z-index:70;background:rgba(0,0,0,.5);align-items:center;justify-content:center;padding:18px}.modal.open{display:flex}.modalbox{width:min(960px,100%);max-height:92vh;overflow:auto;background:white;border-radius:24px;padding:20px}.modalhead{display:flex;justify-content:space-between;gap:12px;align-items:start}.modalhead h3{margin:0;font-size:27px}

.license{display:none;position:fixed;inset:0;z-index:110;background:linear-gradient(135deg,#142a20,#2f604b);align-items:center;justify-content:center;padding:20px}.license.open{display:flex}.licensebox{background:white;border-radius:24px;padding:28px;width:min(500px,100%)}.licensebox h2{margin:0 0 4px;color:#183326}.licensebox .muted{color:#68746c;font-size:14px;margin:0 0 16px}.licensebox input{width:100%;border:1px solid #ddd5c7;border-radius:13px;padding:12px;font-size:16px;min-height:44px;box-sizing:border-box;margin-bottom:10px;text-align:center;font-family:monospace;font-size:18px;letter-spacing:1px}.licensebox .btn{width:100%;text-align:center;display:block;box-sizing:border-box}.licensebox .divider{display:flex;align-items:center;gap:8px;margin:14px 0;color:#68746c;font-size:13px}.licensebox .divider::before,.licensebox .divider::after{content:'';flex:1;border-bottom:1px solid #ddd5c7}.licensebox .trylink{text-align:center;margin-top:12px}.licensebox .trylink a{color:#2f604b;text-decoration:underline;font-size:14px}.licensebox .err{color:#a33b2f;font-size:13px;text-align:center;margin-top:8px;display:none}.licensebox .err.show{display:block}
.lock{display:none;position:fixed;inset:0;z-index:100;background:linear-gradient(135deg,#142a20,#2f604b);align-items:center;justify-content:center;padding:20px}.lock.open{display:flex}.lockbox{background:white;border-radius:24px;padding:22px;width:min(450px,100%)}
@media(max-width:1050px){.appbar{display:flex}.layout{display:block}.side{position:fixed;inset:0 auto 0 0;width:min(82vw,320px);height:100vh;transform:translateX(-105%);transition:.22s ease;box-shadow:22px 0 70px rgba(0,0,0,.28)}.side.open{transform:translateX(0)}.nav{display:grid!important}.nav button{white-space:normal;font-size:15px}main{padding:15px}.top{display:grid}.top .actions{display:grid;grid-template-columns:1fr 1fr}.top .actions .btn:first-child{grid-column:1/-1}.stats,.three,.two,.animals,.photos,.idgrid,.formgrid,.thumbs{grid-template-columns:1fr}.batch{grid-template-columns:1fr}.match{grid-template-columns:1fr}.match img{width:100%;height:175px}.card{padding:15px}}
@media print{.side,.appbar,.actions,.toolbar,.btn{display:none!important}.layout{display:block}main{padding:0}.card{box-shadow:none}}
</style>
</head>
<body>

<div class="license" id="licenseLock"><div class="licensebox"><h2>🐄 HerdLook v1.2</h2><p class="muted">Enter your license key to activate the full version.</p><div class="field"><label style="font-weight:800;font-size:13px;color:#344238">License Key</label><input id="licenseKeyInput" type="text" placeholder="JRT-XXXX-XXXX-XXXX" autocomplete="off" spellcheck="false"></div><button class="btn primary" id="activateBtn" onclick="activateLicense()">Activate HerdLook</button><div class="err" id="licenseErr"></div><div class="divider">or</div><div class="trylink"><a href="https://verdant-igloo-cax7.here.now/" target="_blank" rel="noopener noreferrer">Try the Free Demo Beta →</a></div><p class="muted" style="margin-top:12px;font-size:12px;text-align:center">Purchased from <a href="https://www.jaderosetech.com/store/herdlook" target="_blank" rel="noopener noreferrer" style="color:#2f604b">Jade Rose Technology</a></p></div></div>
<div class="lock" id="lock"><div class="lockbox"><h2>HerdLook v1.2 Locked</h2><p class="muted">Enter local PIN/password.</p><div class="field"><label>PIN/password</label><input id="unlockPin" type="password"></div><button class="btn primary" id="unlockBtn" style="width:100%">Unlock</button><p id="unlockErr" class="muted hidden" style="color:var(--bad)">Incorrect PIN/password.</p></div></div>
<div class="appbar"><div class="mbrand"><div class="logo">🐄</div><div><strong>HerdLook</strong><small>HerdLook v1.2 by JRT</small></div></div><button class="hamb" id="menuBtn">☰</button></div><div class="backdrop" id="backdrop"></div>
<div class="layout">
<aside class="side" id="side"><div class="brand"><div class="logo">🐄</div><div><h1>HerdLook</h1><p>Herd records PWA</p><div class="byline">by Jade Rose Technology</div></div></div><nav class="nav" id="nav">
<button class="active" data-view="dashboard">🏠 <span class="label">Dashboard</span></button><button data-view="herd">🐂 <span class="label">Herd</span></button><button data-view="photos">🖼️ <span class="label">Animal Photos</span></button><button data-view="lookup">📷 <span class="label">Camera Lookup</span></button><button data-view="guide">✅ <span class="label">Photo Guide</span></button><button data-view="records">🩺 <span class="label">Records</span></button><button data-view="documents">🗂️ <span class="label">Documents</span></button><button data-view="locations">🗺️ <span class="label">Map/Locations</span></button><button data-view="owner">👤 <span class="label">Owner/Farm</span></button><button data-view="privacy">🔒 <span class="label">Data/Privacy</span></button><button data-view="settings">⚙️ <span class="label">Settings</span></button>
</nav><div class="notice" style="margin-top:18px;background:rgba(255,255,255,.1);color:white;border-color:rgba(255,255,255,.2)">HerdLook v1.2 — local-only storage. No cloud database or sync.</div></aside>
<main>
<header class="top"><div><h2 id="title">Dashboard</h2><p id="sub">Manage animal profiles, photos, camera lookup, and herd records.</p></div><div class="actions"><button class="btn" onclick="view('guide')">Getting Started</button><button class="btn primary" onclick="openAnimal()">+ Add Animal</button><button class="btn accent" onclick="view('lookup')">Camera Lookup</button></div></header>

<section id="dashboard" class="view">
<div class="notice"><b>HerdLook v1.2:</b> Dashboard loads first. The logo/menu opens as a clean left drawer. Animal IDs are grouped by category cards to save mobile space.</div>
<div class="grid stats"><div class="card stat"><small>Total Animals</small><strong id="sAnimals">0</strong><small>Active profiles</small></div><div class="card stat"><small>Reference Photos</small><strong id="sPhotos">0</strong><small>Saved for lookup</small></div><div class="card stat"><small>Records</small><strong id="sRecords">0</strong><small>Herd history</small></div><div class="card stat"><small>Due Soon</small><strong id="sDue">0</strong><small>Follow-ups</small></div></div>
<div class="card" style="margin-top:14px"><div class="row"><div><h3 style="margin:0">Animals by Category</h3><p class="muted">Tap a card to list ID numbers by type.</p></div><button class="btn" onclick="selectCat('')">Show All</button></div><div id="catCards" class="grid three" style="margin-top:12px"></div><div id="catIds" class="idgrid"></div></div>
<div class="grid two" style="margin-top:14px"><div class="card"><div class="row"><div><h3 style="margin:0">Recent Animals</h3><p class="muted">Hidden by default for mobile space.</p></div><button class="btn" id="recentBtn" onclick="toggleRecent()">Show Recent</button></div><div id="recent" class="hidden"></div></div><div class="card"><h3 style="margin-top:0">Owner/Farm</h3><div id="ownerSummary"></div></div></div>
</section>

<section id="herd" class="view hidden"><div class="toolbar"><input id="search" placeholder="Search ID, name, breed, location, dam, sire..."><select id="catFilter"><option value="">All categories</option></select><select id="sort"><option value="">Sort: newest added</option><option value="dob">Sort: birth date / age</option><option value="added">Sort: date added</option><option value="id">Sort: animal ID</option></select><select id="sortOrder"><option value="desc">Order: youngest / newest first</option><option value="asc">Order: oldest / earliest first</option></select><button class="btn" onclick="toggleBatch()">Batch Edit</button><button class="btn primary" onclick="openAnimal()">+ Add Animal</button></div><div id="animalList" class="animals"></div><div id="batchPanel" class="card hidden" style="margin-top:14px"><div class="row"><div><h3 style="margin:0">Batch Edit</h3><p class="muted">Change repeated info and save all edits with one click.</p></div><button class="btn primary" onclick="saveBatch()">Save All Edits</button></div><div id="batchList"></div></div></section>

<section id="photos" class="view hidden"><div class="toolbar"><input id="photoSearch" placeholder="Search animal photos..."><select id="photoCat"><option value="">All categories</option></select></div><div class="card"><h3 style="margin-top:0">Animal Photo Cards</h3><p class="muted">Photos live behind this button/page so herd cards stay compact on mobile.</p><div id="photoCards" class="photos"></div></div></section>

<section id="lookup" class="view hidden"><div class="card"><h3 style="margin-top:0">Camera Lookup</h3><div class="notice"><b>Camera-assisted lookup:</b> Uses multi-photo weighted comparison in the browser. It suggests matches only. Always manually confirm.</div><div class="grid two"><div><div class="field"><label>Take/upload photo</label><input id="lookupFile" type="file" accept="image/*" capture="environment"></div><div id="lookupPreview" class="card muted" style="height:280px;display:grid;place-items:center">No photo selected</div></div><div><h4>Suggested matches</h4><div id="matches"><div class="record muted">Upload a photo to compare against animal reference photos.</div></div></div></div></div></section>

<section id="guide" class="view hidden"><div class="card"><h3 style="margin-top:0">Photo Capture Best Practices</h3><div class="notice"><b>Minimum beta requirement:</b> 3 clear photos: front face, left side, right side. Recommended: 6–8 photos per animal.</div><div class="grid two"><div class="card"><h4>Cattle: 6 photos</h4><ol><li>Front face</li><li>Left side full body</li><li>Right side full body</li><li>Rear view</li><li>Ear tag / brand close-up</li><li>Unique marking or muzzle/nose close-up</li></ol></div><div class="card"><h4>Horses: 7 photos</h4><ol><li>Front face</li><li>Left side full body</li><li>Right side full body</li><li>Rear view</li><li>Face / blaze close-up</li><li>Legs / socks / markings</li><li>Brand, scar, or unique marking</li></ol></div></div><h4>Quality rules</h4><ul><li>Use good daylight or even barn lighting.</li><li>Keep the animal filling most of the frame.</li><li>Avoid blur, fences, shadows, people, and other animals blocking the view.</li><li>Update photos after seasonal coat changes, new tags, injury, grooming, or weight change.</li></ul></div></section>

<section id="records" class="view hidden"><div class="toolbar"><input id="recordSearch" placeholder="Search records..."><select id="recordType"><option value="">All record types</option><option>Health</option><option>Weight</option><option>Breeding</option><option>Movement</option><option>Note</option><option>Sale/Transfer</option></select><button class="btn primary" onclick="openRecord()">+ Add Record</button></div><div class="card"><h3 style="margin-top:0">Records</h3><div id="recordList"></div></div></section>

<section id="documents" class="view hidden"><div class="grid two"><div class="card"><h3 style="margin-top:0">Add Document</h3><form id="docForm"><div class="field"><label>Title</label><input id="docTitle" required></div><div class="field"><label>Type</label><select id="docType"><option>Vet / Health</option><option>Registration</option><option>Bill of Sale</option><option>Receipt</option><option>Lab / Test Result</option><option>Other</option></select></div><div class="field"><label>Attach to animal</label><select id="docAnimal"></select></div><div class="field"><label>File</label><input id="docFile" type="file" required></div><div class="field"><label>Notes</label><textarea id="docNotes"></textarea></div><button class="btn primary">Save Document</button></form></div><div class="card"><h3 style="margin-top:0">Stored Documents</h3><div id="docList"></div></div></div></section>

<section id="locations" class="view hidden"><div class="grid two"><div class="card"><h3 style="margin-top:0">Location</h3><form id="locForm"><div class="field"><label>Name</label><input id="locName" required></div><div class="field"><label>Type</label><select id="locType"><option>Pasture</option><option>Barn</option><option>Lot / Pen</option><option>Water</option><option>Gate</option><option>Handling Area</option><option>Quarantine</option><option>Other</option></select></div><div class="field"><label>Notes</label><textarea id="locNotes"></textarea></div><button class="btn primary">Save Location</button></form></div><div class="card"><h3 style="margin-top:0">Locations</h3><div id="locList"></div></div></div></section>

<section id="owner" class="view hidden"><div class="card"><h3 style="margin-top:0">Owner & Farm/Ranch Info</h3><form id="ownerForm" class="formgrid"><div class="field"><label>Owner name</label><input id="ownerName"></div><div class="field"><label>Farm/Ranch name</label><input id="farmName"></div><div class="field"><label>Phone</label><input id="ownerPhone"></div><div class="field"><label>Email</label><input id="ownerEmail" type="email"></div><div class="field full"><label>Address</label><input id="farmAddress"></div><div class="field"><label>Primary animal type</label><input id="farmType"></div><div class="field"><label>Vet / clinic</label><input id="vetInfo"></div><div class="field full"><label>Notes</label><textarea id="farmNotes"></textarea></div><button class="btn primary full">Save Owner/Farm Info</button></form></div></section>

<section id="privacy" class="view hidden"><div class="grid two"><div class="card"><h3 style="margin-top:0">Local-Only Data</h3><p>HerdLook stores data in this browser/device by default. No Firebase, Supabase, cloud database, server accounts, or automatic cloud sync.</p><div class="notice">Export backups regularly. Clearing browser data can delete local HerdLook records.</div></div><div class="card"><h3 style="margin-top:0">Backup / Restore</h3><div class="notice"><b>Import note:</b> You can import a backup even with existing data. You'll be asked to confirm before replacing. Both old and new backup formats are supported.</div><div class="actions"><button class="btn primary" onclick="exportBackup()">Export Full Backup</button><input id="importFile" type="file" accept=".json,application/json"><button class="btn" onclick="importBackup()">Import Backup</button></div></div></div></section>

<section id="settings" class="view hidden"><div class="card"><h3 style="margin-top:0">Security & Data</h3><div class="field"><label>Set local PIN/password</label><input id="pin" type="password"></div><div class="actions"><button class="btn primary" onclick="savePin()">Save PIN</button><button class="btn" onclick="lockNow()">Lock Now</button><button class="btn danger" onclick="clearPin()">Remove PIN</button><button class="btn" onclick="seed()">Load Demo Herd</button><button class="btn danger" onclick="clearAll()">Clear Local Data</button></div><div class="notice" style="margin-top:14px"><b>HerdLook v1.2:</b> This is the full paid version. Local-only storage with unlimited animals, records, documents, locations, and photos. Keep backups regular.</div><div class="notice"><b>Import rule:</b> A backup import must not overwrite existing data. User must clear/delete old data first, then import.</div></div></section>
</main></div>

<div class="modal" id="animalModal"><div class="modalbox"><div class="modalhead"><div><h3 id="animalTitle">Add Animal</h3><p class="muted">One-click save handles profile info and photos together.</p></div><button class="btn" onclick="closeModal('animalModal')">Close</button></div><form id="animalForm" class="formgrid"><input id="animalId" type="hidden">
<div class="field"><label>Animal ID *</label><input id="aCode" required></div><div class="field"><label>Name</label><input id="aName"></div>
<div class="field"><label>Species</label><select id="aSpecies"><option>Cattle</option><option>Horse</option><option>Goat</option><option>Sheep</option><option>Other</option></select></div><div class="field"><label>Category *</label><select id="aCategory"></select></div>
<div class="field"><label>Breed</label><input id="aBreed" list="breedList"><datalist id="breedList"></datalist><div id="breedChips" class="chips"></div></div><div class="field"><label>Sex</label><select id="aSex"><option></option><option>Female</option><option>Male</option><option>Cow</option><option>Bull</option><option>Steer</option><option>Heifer</option><option>Mare</option><option>Stallion</option><option>Gelding</option></select></div>
<div class="field"><label>Date of birth</label><input id="aDob" type="date"><small class="muted">Calendar opens for month, day, and year.</small></div><div class="field"><label>Tag / RFID / microchip</label><input id="aTag"></div>
<div class="field"><label>Location</label><input id="aLoc" list="locListData"><datalist id="locListData"></datalist><div id="locChips" class="chips"></div></div><div class="field"><label>Dam information</label><input id="aDam"></div><div class="field"><label>Sire information</label><input id="aSire"></div>
<div class="field full"><label>Markings / notes</label><textarea id="aMark"></textarea></div>
<div class="field full"><label>Reference photos</label><div class="notice"><b>Minimum:</b> front face, left side, right side. <b>Recommended:</b> 6–8 photos.</div><input id="aPhotos" type="file" accept="image/*" multiple><p id="photoHint" class="muted"></p><div id="photoPreview" class="thumbs"></div></div>
<div class="actions full"><button type="button" class="btn danger" id="deleteAnimal" onclick="deleteAnimal()">Delete</button><button class="btn primary">Save Animal & Photos</button></div></form></div></div>

<div class="modal" id="recordModal"><div class="modalbox"><div class="modalhead"><h3>Add Record</h3><button class="btn" onclick="closeModal('recordModal')">Close</button></div><form id="recForm" class="formgrid"><div class="field"><label>Animal</label><select id="rAnimal" required></select></div><div class="field"><label>Type</label><select id="rType"><option>Health</option><option>Weight</option><option>Breeding</option><option>Movement</option><option>Note</option><option>Sale/Transfer</option></select></div><div class="field"><label>Date</label><input id="rDate" type="date" required></div><div class="field"><label>Follow-up date</label><input id="rFollow" type="date"></div><div class="field full"><label>Details</label><textarea id="rDetails" required></textarea></div><button class="btn primary full">Save Record</button></form></div></div>

<script>
const K="herdlook_v12", cats=["Cow","Bull","Bull Calf","Heifer Calf","Heifer","Steer","Horse","Other"];
let S={animals:[],records:[],docs:[],locations:[],owner:{},pin:"",photos:[],cat:"",recent:false,batch:false,view:"dashboard"};
const $=id=>document.getElementById(id), esc=s=>String(s??"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m])), id=()=>crypto.randomUUID?crypto.randomUUID():Date.now()+""+Math.random();
const label=a=>[a.code,a.name].filter(Boolean).join(" — ")||"Unnamed", cat=a=>a.category||"Other", today=()=>new Date().toISOString().slice(0,10);
function save(){localStorage.setItem(K,JSON.stringify(S))}
function load(){try{Object.assign(S,JSON.parse(localStorage.getItem(K))||{})}catch{}}
function closeDrawer(){side.classList.remove("open");backdrop.classList.remove("open")}function openDrawer(){side.classList.add("open");backdrop.classList.add("open")}
menuBtn.onclick=openDrawer;backdrop.onclick=closeDrawer;
function view(v){S.view=v;document.querySelectorAll(".view").forEach(x=>x.classList.add("hidden"));$(v).classList.remove("hidden");document.querySelectorAll(".nav button").forEach(b=>b.classList.toggle("active",b.dataset.view===v));closeDrawer();const t={dashboard:["Dashboard","Manage animal profiles, photos, camera lookup, and herd records."],herd:["Herd","List, filter, sort, and batch-edit animals."],photos:["Animal Photos","Photo cards live here to save mobile space."],lookup:["Camera Lookup","Take or upload a photo and confirm suggested matches."],guide:["Photo Guide","Best practices for reference photos."],records:["Records","Health, weight, breeding, movement, notes, and sales."],documents:["Documents","Store local documents."],locations:["Map/Locations","Pastures, barns, pens, gates, and water points."],owner:["Owner/Farm","Owner and farm/ranch info."],privacy:["Data/Privacy","Local-only storage and backup."],settings:["Settings","PIN, demo data, and local testing."]}[v];title.textContent=t[0];sub.textContent=t[1];render()}
nav.onclick=e=>{let b=e.target.closest("button[data-view]");if(b)view(b.dataset.view)}
function countPhotos(){return S.animals.reduce((n,a)=>n+(a.photos||[]).length,0)}
function render(){renderCats();renderStats();renderHerd();renderPhotos();renderRecords();renderDocs();renderLocs();renderOwner();renderSelects();renderBatch();renderSuggestions();renderLock()}
function renderStats(){sAnimals.textContent=S.animals.length;sPhotos.textContent=countPhotos();sRecords.textContent=S.records.length;sDue.textContent=S.records.filter(r=>r.follow&&new Date(r.follow)-new Date(today())<=12096e5&&new Date(r.follow)>=new Date(today())).length;recent.classList.toggle("hidden",!S.recent);recentBtn.textContent=S.recent?"Hide Recent":"Show Recent";recent.innerHTML=S.animals.slice(-5).reverse().map(a=>`<div class="record"><b>${esc(label(a))}</b><br><span class="muted">${esc(cat(a))} • ${esc(a.location||"No location")} • ${esc(a.tag||"No tag")}</span></div>`).join("")||'<div class="record muted">No animals yet.</div>'}
function renderCats(){catCards.innerHTML=cats.map(c=>{let arr=S.animals.filter(a=>cat(a)==c),ids=arr.map(a=>a.code||a.name||"No ID").slice(0,5).join(", ");return`<button class="card catcard ${S.cat==c?"active":""}" onclick="selectCat('${c}')"><small>${c}</small><strong>${arr.length}</strong><small>${esc(ids||"No animals")}</small></button>`}).join("");let arr=S.cat?S.animals.filter(a=>cat(a)==S.cat):S.animals;catIds.innerHTML=arr.map(a=>`<button class="idbtn" onclick="openAnimal('${a.id}')"><strong>${esc(a.code||a.name)}</strong><small class="muted">${esc(cat(a))} • ${esc(a.breed||"No breed")} • ${esc(a.location||"No location")}</small></button>`).join("")||'<div class="record muted">No animals in this category.</div>'}
function selectCat(c){S.cat=S.cat==c?"":c;renderCats()}
function toggleRecent(){S.recent=!S.recent;renderStats()}
function filtered(){
  let q=(search?.value||"").toLowerCase(),c=catFilter?.value||"",mode=sort?.value||"",order=sortOrder?.value||"desc";
  let arr=S.animals.filter(a=>[a.code,a.name,a.breed,a.location,a.dam,a.sire,a.tag,cat(a)].join(" ").toLowerCase().includes(q)&&(!c||cat(a)==c));
  const dir=order==="asc"?1:-1;
  if(mode==="dob"){
    arr.sort((a,b)=>{
      let av=a.dob?new Date(a.dob).getTime():0,bv=b.dob?new Date(b.dob).getTime():0;
      return (av-bv)*dir;
    });
  } else if(mode==="added"){
    arr.sort((a,b)=>{
      let av=a.createdAt?new Date(a.createdAt).getTime():0,bv=b.createdAt?new Date(b.createdAt).getTime():0;
      return (av-bv)*dir;
    });
  } else if(mode==="id"){
    arr.sort((a,b)=>String(a.code||a.name||"").localeCompare(String(b.code||b.name||""))*dir);
  } else {
    arr.sort((a,b)=>new Date(b.createdAt||0)-new Date(a.createdAt||0));
  }
  return arr
}
function renderHerd(){if(!animalList)return;animalList.innerHTML=filtered().map(a=>`<div class="card"><div class="row"><div><b>${esc(label(a))}</b><p class="muted">${esc(a.breed||"No breed")}</p></div><span class="pill">${esc(cat(a))}</span></div><p class="muted">${esc(a.location||"No location")} • ${esc(a.tag||"No tag")}</p><p class="muted">Dam: ${esc(a.dam||"Not set")} • Sire: ${esc(a.sire||"Not set")}</p><div class="actions"><button class="btn" onclick="openAnimal('${a.id}')">Open/Edit</button><button class="btn" onclick="openPhotoPage('${a.id}')">Photos (${(a.photos||[]).length})</button><button class="btn primary" onclick="openRecord('${a.id}')">Add Record</button></div></div>`).join("")||'<div class="card muted">No animals found.</div>'}
function renderPhotos(){if(!photoCards)return;let q=(photoSearch?.value||"").toLowerCase(),c=photoCat?.value||"";let arr=S.animals.filter(a=>[a.code,a.name,a.breed,a.location,cat(a)].join(" ").toLowerCase().includes(q)&&(!c||cat(a)==c));photoCards.innerHTML=arr.map(a=>`<div class="photoCard">${a.photos?.[0]?`<img src="${a.photos[0].src}">`:'<div style="height:210px;display:grid;place-items:center" class="muted">No photo</div>'}<div style="padding:12px"><b>${esc(label(a))}</b><p class="muted">${esc(cat(a))} • ${(a.photos||[]).length} photos</p><div class="actions"><button class="btn" onclick="openAnimal('${a.id}')">Add/Edit Photos</button></div></div></div>`).join("")||'<div class="record muted">No photo cards found.</div>'}
function openPhotoPage(animalId){view("photos");let a=S.animals.find(x=>x.id==animalId);photoSearch.value=a?(a.code||a.name):"";renderPhotos()}
function renderBatch(){batchPanel.classList.toggle("hidden",!S.batch);batchList.innerHTML=S.animals.map(a=>`<div class="batch" data-id="${a.id}"><div class="field"><label>${esc(a.code||a.name)} category</label><select class="bcat">${cats.map(c=>`<option ${cat(a)==c?"selected":""}>${c}</option>`).join("")}</select></div><div class="field"><label>Breed</label><input class="bbreed" value="${esc(a.breed||"")}"></div><div class="field"><label>Location</label><input class="bloc" value="${esc(a.location||"")}"></div><button class="btn" onclick="openAnimal('${a.id}')">Open</button></div>`).join("")}
function toggleBatch(){S.batch=!S.batch;renderBatch()}
function saveBatch(){document.querySelectorAll(".batch").forEach(r=>{let a=S.animals.find(x=>x.id==r.dataset.id);if(a){a.category=r.querySelector(".bcat").value;a.breed=r.querySelector(".bbreed").value.trim();a.location=r.querySelector(".bloc").value.trim();a.updatedAt=new Date().toISOString()}});save();render();alert("All edits saved.")}
function unique(f){return[...new Set(S.animals.map(a=>(a[f]||"").trim()).filter(Boolean))].slice(-8).reverse()}
function renderSuggestions(){breedList.innerHTML=unique("breed").map(v=>`<option value="${esc(v)}">`).join("");locListData.innerHTML=unique("location").map(v=>`<option value="${esc(v)}">`).join("");breedChips.innerHTML=unique("breed").map(v=>`<button type="button" class="chip" onclick="aBreed.value='${esc(v)}'">${esc(v)}</button>`).join("");locChips.innerHTML=unique("location").map(v=>`<button type="button" class="chip" onclick="aLoc.value='${esc(v)}'">${esc(v)}</button>`).join("")}
function openModal(m){$(m).classList.add("open")}function closeModal(m){$(m).classList.remove("open")}
function openAnimal(animalId){animalForm.reset();animalIdEl=animalId;let last=S.animals.at(-1);S.photos=[];deleteAnimal.classList.toggle("hidden",!animalId);if(last&&!animalId){aSpecies.value=last.species||"Cattle";aCategory.value=last.category||"Cow";aBreed.value=last.breed||"";aLoc.value=last.location||""}let a=S.animals.find(x=>x.id==animalId);animalTitle.textContent=a?"Edit Animal":"Add Animal";if(a){animalId.value=a.id;aCode.value=a.code||"";aName.value=a.name||"";aSpecies.value=a.species||"Cattle";aCategory.value=a.category||cat(a);aBreed.value=a.breed||"";aSex.value=a.sex||"";aDob.value=a.dob||"";aTag.value=a.tag||"";aLoc.value=a.location||"";aDam.value=a.dam||"";aSire.value=a.sire||"";aMark.value=a.markings||"";S.photos=structuredClone(a.photos||[])}renderPhotoPreview();openModal("animalModal")}
function renderPhotoPreview(){let n=S.photos.length;photoHint.textContent=`${n} reference photo${n==1?"":"s"} added. ${n>=6?"Good set.":n>=3?"Minimum reached; add more for better recognition.":"Add at least "+(3-n)+" more."}`;photoPreview.innerHTML=S.photos.map(p=>`<div class="thumb"><img src="${p.src}"></div>`).join("")}
function fileUrl(file){return new Promise((res,rej)=>{let r=new FileReader();r.onload=()=>res(r.result);r.onerror=rej;r.readAsDataURL(file)})}
function sig(src){return new Promise((res,rej)=>{let im=new Image();im.onload=()=>{let c=document.createElement("canvas"),x=c.getContext("2d",{willReadFrequently:true});c.width=c.height=32;x.drawImage(im,0,0,32,32);let d=x.getImageData(0,0,32,32).data,gray=[],sum=0,h=Array(24).fill(0);for(let i=0;i<d.length;i+=4){let r=d[i],g=d[i+1],b=d[i+2],y=.299*r+.587*g+.114*b;gray.push(y);sum+=y;h[Math.min(7,r>>5)]++;h[8+Math.min(7,g>>5)]++;h[16+Math.min(7,b>>5)]++}let avg=sum/gray.length;res({hash:gray.map(v=>v>=avg?"1":"0").join(""),hist:h.map(v=>v/gray.length)})};im.onerror=rej;im.src=src})}
function cmp(a,b){if(!a||!b)return 0;let same=0;for(let i=0;i<a.hash.length;i++)if(a.hash[i]==b.hash[i])same++;let hd=same/a.hash.length,dist=0;for(let i=0;i<a.hist.length;i++)dist+=Math.abs(a.hist[i]-b.hist[i]);return Math.round((hd*.65+Math.max(0,1-dist/6)*.35)*100)}
aPhotos.onchange=async e=>{for(const f of e.target.files){let src=await fileUrl(f);S.photos.push({id:id(),src,signature:await sig(src),createdAt:new Date().toISOString()})}aPhotos.value="";renderPhotoPreview()}
animalForm.onsubmit=e=>{e.preventDefault();let existing=S.animals.find(a=>a.id==animalId.value),a={id:animalId.value||id(),code:aCode.value.trim(),name:aName.value.trim(),species:aSpecies.value,category:aCategory.value,breed:aBreed.value.trim(),sex:aSex.value,dob:aDob.value,tag:aTag.value.trim(),location:aLoc.value.trim(),dam:aDam.value.trim(),sire:aSire.value.trim(),markings:aMark.value.trim(),photos:S.photos,updatedAt:new Date().toISOString(),createdAt:existing?.createdAt||new Date().toISOString()};if(existing)Object.assign(existing,a);else S.animals.push(a);save();closeModal("animalModal");render()}
function deleteAnimal(){if(!animalId.value||!confirm("Delete this animal and its records?"))return;S.animals=S.animals.filter(a=>a.id!=animalId.value);S.records=S.records.filter(r=>r.animalId!=animalId.value);save();closeModal("animalModal");render()}
function renderSelects(){[catFilter,photoCat,aCategory].forEach(sel=>{if(!sel)return;let val=sel.value;sel.innerHTML=(sel==aCategory?"":"<option value=''>All categories</option>")+cats.map(c=>`<option>${c}</option>`).join("");sel.value=val|| (sel==aCategory?"Cow":"")});rAnimal.innerHTML=S.animals.map(a=>`<option value="${a.id}">${esc(label(a))}</option>`).join("");docAnimal.innerHTML="<option value=''>General</option>"+S.animals.map(a=>`<option value="${a.id}">${esc(label(a))}</option>`).join("")}
function openRecord(animalId){recForm.reset();rDate.value=today();renderSelects();if(animalId)rAnimal.value=animalId;openModal("recordModal")}
recForm.onsubmit=e=>{e.preventDefault();S.records.push({id:id(),animalId:rAnimal.value,type:rType.value,date:rDate.value,follow:rFollow.value,details:rDetails.value.trim(),createdAt:new Date().toISOString()});save();closeModal("recordModal");render()}
function renderRecords(){let q=(recordSearch?.value||"").toLowerCase(),t=recordType?.value||"";recordList.innerHTML=S.records.slice().reverse().filter(r=>{let a=S.animals.find(x=>x.id==r.animalId);return(!t||r.type==t)&&[r.type,r.date,r.details,a?label(a):""].join(" ").toLowerCase().includes(q)}).map(r=>{let a=S.animals.find(x=>x.id==r.animalId);return`<div class="record"><div class="row"><div><b>${esc(r.type)} — ${esc(a?label(a):"Unknown")}</b><br><span class="muted">${esc(r.date)} ${r.follow?"• Follow-up "+esc(r.follow):""}</span></div><button class="btn danger" onclick="delRecord('${r.id}')">Delete</button></div><p>${esc(r.details)}</p></div>`}).join("")||'<div class="record muted">No records.</div>'}
function delRecord(rid){S.records=S.records.filter(r=>r.id!=rid);save();render()}
docForm.onsubmit=async e=>{e.preventDefault();let f=docFile.files[0];S.docs.push({id:id(),title:docTitle.value,type:docType.value,animalId:docAnimal.value,fileName:f.name,src:await fileUrl(f),notes:docNotes.value,createdAt:new Date().toISOString()});docForm.reset();save();render()}
function renderDocs(){docList.innerHTML=S.docs.slice().reverse().map(d=>`<div class="doc"><div class="row"><div><a href="${d.src}" download="${esc(d.fileName)}"><b>${esc(d.title)}</b></a><br><span class="muted">${esc(d.type)} • ${esc(d.fileName)}</span></div><button class="btn danger" onclick="S.docs=S.docs.filter(x=>x.id!='${d.id}');save();render()">Delete</button></div><p>${esc(d.notes||"")}</p></div>`).join("")||'<div class="doc muted">No documents.</div>'}
locForm.onsubmit=e=>{e.preventDefault();S.locations.push({id:id(),name:locName.value,type:locType.value,notes:locNotes.value});locForm.reset();save();render()}
function renderLocs(){locList.innerHTML=S.locations.map(l=>`<div class="loc"><div class="row"><div><b>${esc(l.name)}</b><br><span class="muted">${esc(l.type)}</span></div><button class="btn danger" onclick="S.locations=S.locations.filter(x=>x.id!='${l.id}');save();render()">Delete</button></div><p>${esc(l.notes||"")}</p></div>`).join("")||'<div class="loc muted">No locations.</div>'}
ownerForm.onsubmit=e=>{e.preventDefault();S.owner={ownerName:ownerName.value,farmName:farmName.value,ownerPhone:ownerPhone.value,ownerEmail:ownerEmail.value,farmAddress:farmAddress.value,farmType:farmType.value,vetInfo:vetInfo.value,farmNotes:farmNotes.value};save();render();alert("Owner/Farm info saved.")}
function renderOwner(){let o=S.owner||{};ownerSummary.innerHTML=`<p><b>${esc(o.farmName||"Farm/Ranch not set")}</b></p><p class="muted">Owner: ${esc(o.ownerName||"Not set")}<br>Contact: ${esc([o.ownerPhone,o.ownerEmail].filter(Boolean).join(" • ")||"Not set")}<br>Vet: ${esc(o.vetInfo||"Not set")}</p>`;["ownerName","farmName","ownerPhone","ownerEmail","farmAddress","farmType","vetInfo","farmNotes"].forEach(k=>{if($(k))$(k).value=o[k]||""})}
lookupFile.onchange=async e=>{let f=e.target.files[0];if(!f)return;let src=await fileUrl(f);lookupPreview.innerHTML=`<img src="${src}" style="width:100%;height:100%;object-fit:cover;border-radius:12px">`;let s=await sig(src);let ms=S.animals.map(a=>{let scores=(a.photos||[]).map(p=>cmp(s,p.signature)).sort((x,y)=>y-x),best=scores[0]||0,avg=scores.length?Math.round(scores.slice(0,3).reduce((q,v)=>q+v,0)/Math.min(3,scores.length)):0,score=Math.min(99,Math.round(best*.72+avg*.23+Math.min(8,(a.photos||[]).length)));return{a,score}}).filter(m=>m.score).sort((a,b)=>b.score-a.score).slice(0,5);matches.innerHTML=ms.map(m=>`<div class="match">${m.a.photos?.[0]?`<img src="${m.a.photos[0].src}">`:"<div></div>"}<div><b>${esc(label(m.a))}</b><p class="muted">${esc(cat(m.a))} • ${esc(m.a.location||"No location")}</p><div class="bar"><span style="width:${m.score}%"></span></div><small class="muted">${m.score}% camera-assisted suggestion. Confirm manually.</small></div><button class="btn primary" onclick="openAnimal('${m.a.id}')">Confirm/Open</button></div>`).join("")||'<div class="record muted">No reference photos found.</div>'}
function exportBackup(){let blob=new Blob([JSON.stringify(S,null,2)],{type:"application/json"}),u=URL.createObjectURL(blob),a=document.createElement("a");a.href=u;a.download="herdlook-v12-backup-"+today()+".json";a.click();URL.revokeObjectURL(u)}
function hasExistingData(){
  return (S.animals&&S.animals.length)||(S.records&&S.records.length)||(S.docs&&S.docs.length)||(S.locations&&S.locations.length)||
    (S.owner&&Object.keys(S.owner).some(k=>S.owner[k]));
}
async function importBackup(){
  let f=importFile.files[0];
  if(!f)return alert("Choose a backup file first.");
  if(f.size>100*1024*1024)return alert("Backup file is too large (over 100 MB).");
  // Warn but don't block if existing data
  if(hasExistingData()){
    if(!confirm("You have existing data. Importing will replace it. Export a backup first if needed. Continue?"))return;
  }
  let raw, data;
  try{raw=await f.text();data=JSON.parse(raw)}catch(e){alert("Could not read or parse the backup file. Make sure it\'s a valid JSON file exported from HerdLook.");return}
  // Support both old format {animals:[...]} and new format {app:"HerdLook",data:{animals:[...]}}
  let backupData;
  if(data&&data.data&&typeof data.data==="object"&&Array.isArray(data.data.animals)){
    backupData=data.data; // New wrapped format: {app:"HerdLook",data:{animals:[...]}}
  }else if(data&&typeof data==="object"&&Array.isArray(data.animals)){
    backupData=data; // Old flat format: {animals:[...]}
  }else if(data&&typeof data==="object"){
    // Try to find animals array anywhere
    backupData=data.data||data;
  }else{
    alert("This backup file does not look like a valid HerdLook backup. No animal data found.");return;
  }
  // Verify we found something useful
  if(!Array.isArray(backupData.animals)&&!Array.isArray(backupData.records)){
    alert("This backup file does not contain any herd data (animals or records). It may be from a different app.");return;
  }
  // Merge backup data into state, preserving existing fields not in backup
  if(Array.isArray(backupData.animals))S.animals=backupData.animals;
  if(Array.isArray(backupData.records))S.records=backupData.records;
  if(Array.isArray(backupData.docs))S.docs=backupData.docs;else if(Array.isArray(backupData.documents))S.docs=backupData.documents;
  if(Array.isArray(backupData.locations))S.locations=backupData.locations;
  if(backupData.owner&&typeof backupData.owner==="object")S.owner=backupData.owner;else if(backupData.profile&&typeof backupData.profile==="object")S.owner=backupData.profile;
  if(backupData.security&&typeof backupData.security==="object")S.pin=backupData.security.pin||"";else if(typeof backupData.pin==="string")S.pin=backupData.pin;
  save();
  render();
  alert("Backup imported successfully!");
}
function savePin(){S.pin=pin.value;pin.value="";save();alert("PIN saved.")}
function lockNow(){if(!S.pin)return alert("Set a PIN first.");lock.classList.add("open")}
function clearPin(){S.pin="";save();renderLock()}
function renderLock(){if(S.pin&&sessionStorage.getItem("herdlook_v12_unlocked")!="yes")lock.classList.add("open");else lock.classList.remove("open")}
unlockBtn.onclick=()=>{if(unlockPin.value==S.pin){sessionStorage.setItem("herdlook_v12_unlocked","yes");unlockPin.value="";unlockErr.classList.add("hidden");lock.classList.remove("open")}else unlockErr.classList.remove("hidden")}
function clearAll(){
  if(confirm("Clear/delete all old local HerdLook data from this device? Import will only work after old data is deleted. Export a backup first if needed.")){
    localStorage.removeItem(K);
    sessionStorage.removeItem("herdlook_v12_unlocked");
    location.reload();
  }
}
function seed(){S.animals=[{id:id(),code:"C-017",name:"Maple",species:"Cattle",category:"Cow",breed:"Angus Cross",sex:"Cow",dob:"2022-04-15",tag:"RFID-0017",location:"North Pasture",dam:"C-003",sire:"B-012",markings:"Black cow, yellow left ear tag.",photos:[]},{id:id(),code:"B-012",name:"Ranger",species:"Cattle",category:"Bull",breed:"Angus",sex:"Bull",dob:"2020-03-02",tag:"RFID-0012",location:"Bull Lot",dam:"Unknown",sire:"Unknown",markings:"Black bull.",photos:[]},{id:id(),code:"HC-004",name:"Rose",species:"Cattle",category:"Heifer Calf",breed:"Hereford Cross",sex:"Female",dob:"2025-02-10",tag:"HC004",location:"Calf Pen",dam:"C-017",sire:"B-012",markings:"White face.",photos:[]}];S.records=[{id:id(),animalId:S.animals[0].id,type:"Health",date:today(),follow:"",details:"Routine check."}];save();render()}
["search","catFilter","sort","sortOrder","photoSearch","photoCat","recordSearch","recordType"].forEach(i=>setTimeout(()=>$(i)&&($(i).oninput=render,$(i).onchange=render),0));
load();renderSelects();render();if(!S.pin)lock.classList.remove("open");

// === License Key Activation ===
const LICENSE_API="https://www.jaderosetech.com/api/jrt/licenses";
const LICENSE_STORAGE="herdlook_v12_license";

function getFingerprint(){try{let c=localStorage.getItem("jrt_device_fingerprint");if(c)return c;let s=[navigator.userAgent||"",navigator.language||"",String(screen?.width||0),String(screen?.height||0),String(navigator.hardwareConcurrency||0),navigator.platform||""].join("|");let h=5381;for(let i=0;i<s.length;i++){h=(h*33)^s.charCodeAt(i)}let fp="fp_"+(h>>>0).toString(16).padStart(8,"0");try{localStorage.setItem("jrt_device_fingerprint",fp)}catch(e){}return fp}catch(e){return"fp_unknown"}}

function checkLicense(){let lk=localStorage.getItem(LICENSE_STORAGE);if(!lk){document.getElementById("licenseLock").classList.add("open");return false}document.getElementById("licenseLock").classList.remove("open");return true}

async function activateLicense(){let key=document.getElementById("licenseKeyInput").value.trim().toUpperCase();let errEl=document.getElementById("licenseErr");let btn=document.getElementById("activateBtn");if(!key){errEl.textContent="Please enter a license key.";errEl.classList.add("show");return}errEl.classList.remove("show");btn.textContent="Activating...";btn.disabled=true;let fp=getFingerprint();try{let res=await fetch(LICENSE_API+"/activate",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({licenseKey:key,deviceFingerprint:fp,deviceLabel:navigator.userAgent?.slice(0,50)||"Unknown"})});let data=await res.json();if(data.ok){localStorage.setItem(LICENSE_STORAGE,key);document.getElementById("licenseLock").classList.remove("open");alert("HerdLook activated! License key verified for "+data.deviceLimit+" device(s).");location.reload()}else{errEl.textContent=data.message||"Activation failed.";errEl.classList.add("show");btn.textContent="Activate HerdLook";btn.disabled=false}}catch(e){errEl.textContent="Connection error. Please check your internet connection and try again.";errEl.classList.add("show");btn.textContent="Activate HerdLook";btn.disabled=false}}
checkLicense();
</script>
</body>
</html>